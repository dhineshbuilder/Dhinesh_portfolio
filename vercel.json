{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/chat.js": {
      "maxDuration": 30,
      "includeFiles": "{README.md,index.html,package.json,src/**,public/*.svg,public/timeline/*.svg,public/projects/**,public/optimized/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/leetcode",
      "destination": "https://leetcode.com/graphql"
    }
  ]
}
